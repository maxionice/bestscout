{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BestScout",
  "version": "0.1.0",
  "identifier": "io.github.maxionice.bestscout",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{
      "title": "BestScout",
      "width": 1440,
      "height": 900,
      "minWidth": 1100,
      "minHeight": 700,
      "decorations": true,
      "transparent": false
    }],
    "security": { "csp": null }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "category": "Utility",
    "shortDescription": "Linux-first scouting and editing suite for Football Manager"
  }
}
